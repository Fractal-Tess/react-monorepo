{
  "name": "react-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "infisical run -- turbo build",
    "check": "bunx ultracite check packages/convex",
    "dev": "infisical run -- turbo dev",
    "doctor": "bunx ultracite doctor",
    "fix": "bunx ultracite fix packages/convex",
    "lint": "bun run check",
    "format": "bun run fix",
    "prepare": "bunx lefthook install",
    "test": "infisical run -- turbo test",
    "typecheck": "infisical run -- turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@workspace/typescript-config": "workspace:*",
    "lefthook": "^2.1.5",
    "turbo": "^2.9.6",
    "typescript": "6.0.2",
    "ultracite": "7.5.6"
  },
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
