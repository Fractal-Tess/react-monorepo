{
  "name": "react-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "infisical run -- turbo dev",
    "dev:all": "infisical run -- turbo dev",
    "dev:desktop": "turbo dev --filter=@workspace/desktop",
    "dev:mobile": "turbo dev --filter=@workspace/mobile",
    "dev:scraper": "bun run --cwd apps/scraper dev",
    "lint": "bunx turbo run lint",
    "format": "bunx ultracite fix packages/convex"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@workspace/typescript-config": "workspace:*",
    "lefthook": "^2.1.5",
    "turbo": "^2.9.6",
    "typescript": "6.0.2",
    "ultracite": "7.5.6"
  },
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
