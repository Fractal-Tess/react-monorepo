{
  "name": "@workspace/worker",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "infisical run --path=/worker -- bun --watch index.ts",
    "lint": "bunx ultracite check .",
    "start": "infisical run --path=/worker -- bun run index.ts",
    "test": "infisical run --path=/worker -- bun test",
    "typecheck": "infisical run --path=/worker -- tsc --noEmit"
  },
  "dependencies": {
    "@workspace/shared": "workspace:*",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.15.6",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "^6.0.2"
  },
  "module": "index.ts"
}
