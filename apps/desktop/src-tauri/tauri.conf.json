{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "react-monorepo-desktop",
  "version": "0.1.0",
  "identifier": "com.fractaltess.reactmonorepodesktop",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "react-monorepo desktop",
        "width": 1000,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
